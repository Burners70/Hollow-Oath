# Bundle O4 — fastlane snapshot config.
# Captures the static (non-procedural) screens only: title, settings, codex.
# The in-flight/procedural shots (landing, docking, dark-sector, Hollows
# shrine, ECG) stay manual via app/capture-screenshots.sh — no fixed seed
# exists yet to make those reproducible under UI-test automation.

# One-time setup on the Mac (not done by this repo, needs Xcode):
#   1. cd app && bundle exec fastlane snapshot init   (generates SnapshotHelper.swift)
#   2. In Xcode: add a "UI Testing Bundle" target named HollowOathUITests,
#      add HollowOathUITests/ScreenshotUITests.swift and the generated
#      SnapshotHelper.swift to that target.
#   3. bundle exec fastlane snapshot   (run from app/)

devices([
  "iPhone 17 Pro Max",  # largest current bucket
  "iPhone 17",          # standard current bucket
])
# Device names must match whatever's installed in Xcode's current simulator
# runtime (`xcrun simctl list devices`) — Apple retires older iPhone
# simulators as new hardware ships, so these names drift over time. If
# `fastlane snapshot` errors with "not in list of available simulators",
# swap in two names from that error message's list (pick the largest and a
# standard-size one) rather than assuming these are still current.

languages(["en-US"])

# Capacitor generates ios/App/App.xcworkspace — fastlane can't always
# auto-detect it, so point at it explicitly.
workspace("./ios/App/App.xcworkspace")
# Must be the shared UI-test scheme (created alongside HollowOathUITests),
# not the app's own "App" scheme — snapshot runs UI tests, not the app.
scheme("HollowOathUITests")
output_directory("./fastlane/screenshots")
clear_previous_screenshots(true)

# Static screens only — no procedurally-seeded terrain shots here.

node_modules/

# the whole Xcode project is generated fresh by `npx cap add ios` (see
# setup-mac.sh) and re-configured idempotently by configure-ios.sh — nothing
# inside it is hand-authored, so none of it belongs in the repo. Beyond being
# noisy churn on every regen, Xcode's automatic signing can write your
# personal Apple Developer Team ID into project.pbxproj, which must never be
# committed.
ios/

*.xcuserdatad/
